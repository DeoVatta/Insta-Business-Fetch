# Instagram credentials — used for auto cookie refresh when session expires
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Google Sheets output — create a sheet with tabs: Competitors, Vendor, Client, VendorHashtags
# Copy the sheet ID from the URL: docs.google.com/spreadsheets/d/YOUR_SHEETS_ID_HERE/edit
GOOGLE_SHEETS_ID=your_google_sheets_id_here

# Olagon AI Gateway — for AI classification (batch up to 150 profiles per request)
# Get your key from gateway.olagon.site
OLAGON_API_KEY=your_olagon_api_key_here
OLAGON_BASE_URL=https://gateway.olagon.site
